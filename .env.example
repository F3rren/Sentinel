# Copy this file to .env (docker compose loads it automatically, no need to export
# anything in your shell) before pointing Sentinel at a victim. Re-edit it whenever you
# switch to a different victim project.

# ── Victim's Docker network ──────────────────────────────────────────────────────────
# The Docker network name the victim's own docker-compose created, so Sentinel can join
# it and reach the victim by container name (e.g. http://api-gateway:8080) instead of
# localhost. Find the real name with:
#
#   docker network ls
#
# Compose usually prefixes the network with the victim project's folder name, e.g. a
# network named "backend-network" declared inside a project cloned into "some-victim-app"
# becomes "some-victim-app_backend-network" - unless that project's compose file sets an
# explicit top-level `name:` on the network, in which case use that name verbatim.
# Example, for the aquarium-ms victim: VICTIM_NETWORK_NAME=aquarium-ms_aquarium-network
VICTIM_NETWORK_NAME=

# ── Scan tuning (optional) ───────────────────────────────────────────────────────────
# Raise this for victims with a large API surface (e.g. several microservices behind a
# gateway) so a full pass isn't truncated. Leave unset to use the app's own default (25).
SENTINEL_SCAN_MAX_ENDPOINTS=100

# ── Fully automatic scan on startup (optional) ───────────────────────────────────────
# If set, Sentinel scans this URL by itself as soon as it starts and the target becomes
# reachable - no manual POST /api/scans needed. Fetch the outcome any time from
# GET /api/scans/latest. Leave empty to keep triggering scans manually via the API.
# Example, for the aquarium-ms victim: SENTINEL_SCAN_AUTO_TARGET_URL=http://api-gateway:8080
SENTINEL_SCAN_AUTO_TARGET_URL=

# ── Attack modules (optional) ────────────────────────────────────────────────────────
# One on/off switch per module, all default to true. Set to false to skip a module
# entirely for every scan (e.g. it's noisy, out of scope, or you only want a subset).
SENTINEL_SCAN_SQL_INJECTION_ENABLED=true
