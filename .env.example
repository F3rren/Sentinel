# Copy this file to .env (docker compose loads it automatically, no need to export
# anything in your shell) and set it to the actual Docker network name the victim's
# own docker-compose created. Find it with:
#
#   docker network ls
#
# Compose usually prefixes the network with the victim project's folder name, e.g. a
# network named "aquarium-network" inside a project cloned into "aquarium-ms" becomes
# "aquarium-ms_aquarium-network" - unless that project's compose file sets an explicit
# top-level `name:` on the network, in which case use that name verbatim.
AQUARIUM_NETWORK_NAME=aquarium-ms_aquarium-network
